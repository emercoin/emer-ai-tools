# Secrets for the `prod` profile (docker compose --env-file deploy/.env --profile prod).
# The dev profile needs none of these.

# Shared secret between edge and adapter (X-Internal-Key). Required cross-host
# (e.g. wallet/adapter at home, edge on a VPS). Generate: openssl rand -hex 32
ADAPTER_INTERNAL_KEY=

# Session-JWT signing secret for the edge. >=32 bytes. openssl rand -hex 32
EDGE_JWT_SECRET=
