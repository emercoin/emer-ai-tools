# Secrets for the `prod` profile (docker compose --env-file deploy/.env --profile prod).
# The dev profile needs none of these.

# Shared secret between edge and adapter (X-Internal-Key). Required cross-host
# (e.g. wallet/adapter at home, edge on a VPS). Generate: openssl rand -hex 32
ADAPTER_INTERNAL_KEY=

# Session-JWT signing secret for the edge. >=32 bytes. openssl rand -hex 32
EDGE_JWT_SECRET=

# GitHub OAuth App (Developer settings -> OAuth Apps; enable Device Flow).
# Needed for GitHub login in any profile. Device flow uses only the client id;
# the secret is used by the browser web flow's code exchange.
EDGE_GITHUB_CLIENT_ID=
EDGE_GITHUB_CLIENT_SECRET=
# Web flow only (prod, needs a public HTTPS callback on your domain):
# EDGE_WEB_LOGIN_ENABLED=true
# EDGE_GITHUB_REDIRECT_URI=https://ai.emercoin.com/auth/github/callback
