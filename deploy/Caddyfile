# Front for ai.emercoin.com behind Cloudflare (proxied).
#  - Any file that exists under ../site (index, login, css, /docs/*.md, llms.txt,
#    robots.txt, sitemap.xml, …) is served directly and is Cloudflare-cacheable;
#    extensionless paths resolve via try_files (/login -> login.html).
#  - Everything else (the API: /auth, /nvs, /me, /status, /docs, /openapi.json, …)
#    is proxied to the edge.
# The same logic is imported for http:// (CF "Flexible", origin :80) and :443
# (tls internal; CF "Full", origin :443). Origin ports are firewalled to CF.
(app) {
	encode gzip
	root * /srv/site
	@static file {
		try_files {path} {path}.html {path}/index.html
	}
	handle @static {
		rewrite {http.matchers.file.relative}
		file_server
	}
	handle {
		reverse_proxy emer-edge:8000
	}
}

http://ai.emercoin.com {
	import app
}

ai.emercoin.com {
	tls internal
	import app
}
