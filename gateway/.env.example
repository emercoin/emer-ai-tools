# Node RPC target — switch network by changing this (regtest/testnet/mainnet).
GATEWAY_RPC_URL=http://emc:6662
GATEWAY_RPC_USER=emcrpc
GATEWAY_RPC_PASSWORD=emcpass

# Auth
GATEWAY_JWT_SECRET=change-me-to-a-long-random-string
GATEWAY_JWT_TTL_SECONDS=3600

# Rate limit
GATEWAY_FREE_TIER_WRITES_PER_MIN=10
GATEWAY_REDIS_URL=redis://redis:6379/0
