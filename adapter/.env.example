# Node RPC target — switch network by changing this (regtest/testnet/mainnet).
ADAPTER_RPC_URL=http://emc:6662
ADAPTER_RPC_USER=emcrpc
ADAPTER_RPC_PASSWORD=emcpass

# NVS record lifetime (days).
ADAPTER_NVS_DEFAULT_DAYS=30

# Shared-secret gate. Empty = open (dev). Set it when the adapter is reachable
# beyond a trusted network (e.g. wallet at home, edge on a VPS); edge must send
# the same value as EDGE_ADAPTER_KEY.
ADAPTER_INTERNAL_KEY=
