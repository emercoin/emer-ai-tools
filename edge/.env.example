# Node adapter (RPC↔REST). Edge never speaks RPC directly.
EDGE_ADAPTER_URL=http://adapter:8000
# Must match ADAPTER_INTERNAL_KEY when the adapter's gate is enabled.
EDGE_ADAPTER_KEY=

# Auth
EDGE_JWT_SECRET=change-me-to-a-long-random-string   # >=32 bytes unless dev-login is on
EDGE_JWT_TTL_SECONDS=3600

# Login surfaces. Device flow is always on. Raw-token /auth/login is dev/CI only;
# web (browser) flow is opt-in and needs a public callback in prod.
EDGE_DEV_LOGIN_ENABLED=false
EDGE_WEB_LOGIN_ENABLED=false

# GitHub OAuth App (enable Device Flow). Secret only used by the web flow.
EDGE_GITHUB_CLIENT_ID=
EDGE_GITHUB_CLIENT_SECRET=
EDGE_GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Rate limit
EDGE_FREE_TIER_WRITES_PER_MIN=10
EDGE_REDIS_URL=redis://redis:6379/0

# NVS record lifetime (days).
EDGE_NVS_DEFAULT_DAYS=30
